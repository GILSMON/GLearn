# Copy this to .env and fill in your values

# --- Cloud (Supabase) ---
# Get from: Supabase project → Settings → Database → Connection string → URI
# Make sure to append ?sslmode=require for Supabase
DATABASE_URL=postgresql://postgres:[YOUR-PASSWORD]@db.[YOUR-PROJECT].supabase.co:5432/postgres?sslmode=require

# --- Local development ---
# DATABASE_URL=postgresql://[your-mac-user]@localhost/gleam
