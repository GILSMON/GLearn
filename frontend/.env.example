# Copy this to .env and fill in your values

# --- Cloud (after deploying backend to Cloud Run) ---
VITE_API_URL=https://gleam-backend-XXXXXXXXXX-uc.a.run.app

# --- Local development ---
# VITE_API_URL=http://localhost:8080

# --- GitHub Pages base path (repo name) ---
# Only needed if deploying to GitHub Pages under a sub-path like username.github.io/GLearn
# VITE_BASE_PATH=/GLearn/
